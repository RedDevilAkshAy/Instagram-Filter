{
  "manifest_version": 3,
  "name": "Instagram Content Filter",
  "version": "1.0",
  "description": "Filters out specific content on Instagram",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.instagram.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  }
}
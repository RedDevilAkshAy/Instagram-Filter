{
  "manifest_version": 3,
  "name": "Social Media Content Filter",
  "version": "1.1",
  "description": "Filters Instagram and Facebook feeds + productivity overlay",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*", "https://*.facebook.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_icon": "icon.png"
  }
}